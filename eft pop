            && !isGrade11Math
            && !isGrade12Math
            && !isGrade10Accounting
            && !isGrade11Accounting
            && !isGrade12Accounting
        ) return topics;

        const ordered = topics.sort((a, b) => {
            const ia = getCoveredTopicIndex(a);
            const ib = getCoveredTopicIndex(b);

            if (ia !== null && ib !== null) return ia - ib;
            if (ia !== null) return -1;
            if (ib !== null) return 1;
            return String(a).localeCompare(String(b));
        });

        const seen = new Set();
        const deduped = [];
        for (const topicName of ordered) {
            const idx = getCoveredTopicIndex(topicName);
            const displayKey = `display:${normalizeTopicName(getTopicDisplayName(topicName))}`;
            const key = idx !== null ? `idx:${idx}` : `name:${normalizeTopicName(topicName)}`;

            if (seen.has(displayKey)) continue;
            if (seen.has(key)) continue;

            seen.add(key);
            seen.add(displayKey);
            deduped.push(topicName);
        }

        return deduped;
