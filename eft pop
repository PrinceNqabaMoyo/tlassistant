            // Check Final Accounts BEFORE Sole Trader since 'sole trader' appears in both topic names
            if (n.includes('financial accounts') || n.includes('final accounts') || n.includes('year end')) return 'Term 2';
            if (n.includes('sole trader')) return 'Term 1';
            if (n.includes('salaries') || n.includes('wages')) return 'Term 2';
            if (n.includes('vat') || n.includes('value added tax') || n.includes('valued added tax')) return 'Term 2';
