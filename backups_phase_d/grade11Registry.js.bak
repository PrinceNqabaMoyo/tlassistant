import React from 'react';
import Grade11AccountingScaffold from '../grade11/accounting/Grade11AccountingScaffold';
import Grade11ExponentsSurdsScaffold from '../grade11/mathematics/exponents-surds/Grade11ExponentsSurdsScaffold';
import Grade11ExponentsSurdsPractice from '../grade11/mathematics/exponents-surds/Grade11ExponentsSurdsPractice';
import Grade11EquationsInequalitiesScaffold from '../grade11/mathematics/equations-inequalities/Grade11EquationsInequalitiesScaffold';
import Grade11EquationsInequalitiesPractice from '../grade11/mathematics/equations-inequalities/Grade11EquationsInequalitiesPractice';
import Grade11PatternsSequencesScaffold from '../grade11/mathematics/patterns-sequences/Grade11PatternsSequencesScaffold';
import Grade11PatternsSequencesPractice from '../grade11/mathematics/patterns-sequences/Grade11PatternsSequencesPractice';
import Grade11AnalyticalGeometryScaffold from '../grade11/mathematics/analytical-geometry/Grade11AnalyticalGeometryScaffold';
import Grade11AnalyticalGeometryPractice from '../grade11/mathematics/analytical-geometry/Grade11AnalyticalGeometryPractice';

import { useGrade11AccountingController, Grade11AccountingVisualAids } from '../grade11/accounting';
import { useGrade11ExponentsSurdsController, ExponentsSurdsVisualAids as Grade11ExponentsSurdsVisualAids } from '../grade11/mathematics/exponents-surds';
import { useGrade11EquationsInequalitiesController, EquationsInequalitiesVisualAids as Grade11EquationsInequalitiesVisualAids } from '../grade11/mathematics/equations-inequalities';
import { useGrade11PatternsSequencesController, PatternsSequencesVisualAids as Grade11PatternsSequencesVisualAids } from '../grade11/mathematics/patterns-sequences';
import { useGrade11AnalyticalGeometryController, AnalyticalGeometryVisualAids as Grade11AnalyticalGeometryVisualAids } from '../grade11/mathematics/analytical-geometry';

import WorkspaceModeShell from '../shared/WorkspaceModeShell';
import EvaluatedWorkspaceModeShell from '../shared/EvaluatedWorkspaceModeShell';

const h = React.createElement;

const Grade11AccountingRoute = ({ workspaceMode, ctx, subskills, defaultSubskill }) => {
    const controller = useGrade11AccountingController({ workspaceMode, buildApiUrl: ctx.buildApiUrl, subskills, defaultSubskill });

    // State for Practice Navigation
    const [practiceIndex, setPracticeIndex] = React.useState(0);

    // Reset index when mode or subskill changes
    React.useEffect(() => {
        setPracticeIndex(0);
    }, [workspaceMode, controller.practiceSubskill]);

    // Derived current question for practice
    const currentPracticeQuestion = controller.practiceQuestions?.[practiceIndex];

    const renderGrade11AccountingVisualAids = () => h(Grade11AccountingVisualAids, {
        visualAidsTab: controller.visualAidsTab,
        setVisualAidsTab: controller.setVisualAidsTab,
        setVisualAidsOpen: controller.setVisualAidsOpen,
    });

    const commonShellProps = {
        availableModes: ['scaffold', 'practice', 'marking'],
        subskills: controller.subskills,
        difficulty: workspaceMode.endsWith('_scaffold') ? controller.scaffoldDifficulty : controller.practiceDifficulty,
        setDifficulty: workspaceMode.endsWith('_scaffold') ? controller.setScaffoldDifficulty : controller.setPracticeDifficulty,
        subskill: workspaceMode.endsWith('_scaffold') ? controller.scaffoldSubskill : controller.practiceSubskill,
        setSubskill: workspaceMode.endsWith('_scaffold') ? controller.setScaffoldSubskill : controller.setPracticeSubskill,
        onGenerate: (config) => {
            if (workspaceMode.endsWith('_scaffold')) {
                controller.fetchScaffoldQuestion({
                    difficulty: config.difficulty,
                    subskill: config.subskill,
                    seed: controller.scaffoldSeed
                });
            } else {
                controller.fetchPractice({
                    difficulty: config.difficulty,
                    subskill: config.subskill,
                    seed: controller.practiceSeed
                });
            }
        }
    };

    if (workspaceMode.includes('_accounting_') && (workspaceMode.endsWith('_scaffold') || workspaceMode.endsWith('_marking'))) {
        return h(EvaluatedWorkspaceModeShell, {
            workspaceMode,
            setWorkspaceMode: ctx.setWorkspaceMode,
            onBack: ctx.onBack,
            selectedSubject: ctx.selectedSubject,
            selectedGrade: ctx.selectedGrade,
            topic: ctx.topic,
            question: controller.scaffoldQuestion,
            userAnswersCells: controller.scaffoldAnswer?.cells || {},
            questionSlot: h('div', { className: "prose prose-sm max-w-none text-gray-900" }, [
                h('h3', { key: 'title', className: "text-lg font-semibold mb-2" }, controller.scaffoldQuestion?.title || 'Question'),
                h('div', { key: 'prompt', className: "whitespace-pre-wrap" }, controller.scaffoldQuestion?.prompt)
            ]),
            onNext: () => {
                controller.fetchScaffoldQuestion({
                    difficulty: controller.scaffoldDifficulty,
                    subskill: controller.scaffoldSubskill,
                    seed: Math.random()
                });
            },
            renderVisualAids: renderGrade11AccountingVisualAids,

            ...commonShellProps,
        }, h(Grade11AccountingScaffold, {
            isMarkingEnv: workspaceMode.endsWith('_marking'),
            onBack: ctx.onBack,
            subskills: controller.subskills,
            g11AcctVisualAidsOpen: controller.visualAidsOpen,
            setG11AcctVisualAidsOpen: controller.setVisualAidsOpen,
            g11AcctScaffoldDifficulty: controller.scaffoldDifficulty,
            setG11AcctScaffoldDifficulty: controller.setScaffoldDifficulty,
            g11AcctScaffoldSubskill: controller.scaffoldSubskill,
            setG11AcctScaffoldSubskill: controller.setScaffoldSubskill,
            g11AcctScaffoldSeed: controller.scaffoldSeed,
            setG11AcctScaffoldSeed: controller.setScaffoldSeed,
            fetchGrade11AccountingScaffoldQuestion: controller.fetchScaffoldQuestion,
            g11AcctScaffoldLoading: controller.scaffoldLoading,
            g11AcctScaffoldError: controller.scaffoldError,
            g11AcctScaffoldQuestion: controller.scaffoldQuestion,
            g11AcctScaffoldAnswer: controller.scaffoldAnswer,
            setG11AcctScaffoldAnswer: controller.setScaffoldAnswer,
            g11AcctScaffoldFeedback: controller.scaffoldFeedback,
            setG11AcctScaffoldFeedback: controller.setScaffoldFeedback,
            g11AcctScaffoldShowHint: controller.scaffoldShowHint,
            setG11AcctScaffoldShowHint: controller.setScaffoldShowHint,
            renderGrade11AccountingVisualAids,
            hideConfig: true,
            // Pass next/prev handlers if Scaffold supports stepping?
            // Scaffold usually has internal stepping if it's a multi-step problem.
        }));
    }

    // State for Practice Navigation
    if (workspaceMode.includes('_accounting_') && workspaceMode.endsWith('_practice')) {
        return h(WorkspaceModeShell, {
            workspaceMode,
            setWorkspaceMode: ctx.setWorkspaceMode,
            onBack: ctx.onBack,
            selectedSubject: ctx.selectedSubject,
            selectedGrade: ctx.selectedGrade,
            topic: ctx.topic,
            ...commonShellProps,
            renderVisualAids: renderGrade11AccountingVisualAids,
            questionSlot: h('div', { className: "prose prose-sm max-w-none text-gray-900" }, [
                h('h3', { className: "text-lg font-semibold mb-2" }, `Question ${practiceIndex + 1}`),
                h('div', { className: "whitespace-pre-wrap" }, currentPracticeQuestion?.prompt || 'Loading...')
            ]),
            onNext: () => {
                if (controller.practiceQuestions && practiceIndex < controller.practiceQuestions.length - 1) {
                    setPracticeIndex(prev => prev + 1);
                }
            },
            onPrevious: () => {
                if (practiceIndex > 0) {
                    setPracticeIndex(prev => prev - 1);
                }
            },
            // Disable buttons if at ends
            canGoNext: controller.practiceQuestions && practiceIndex < controller.practiceQuestions.length - 1,
            canGoPrevious: practiceIndex > 0,

        }, h(Grade11AccountingPractice, {
            onBack: ctx.onBack,
            subskills: controller.subskills,
            g11AcctVisualAidsOpen: controller.visualAidsOpen,
            setG11AcctVisualAidsOpen: controller.setVisualAidsOpen,
            g11AcctPracticeDifficulty: controller.practiceDifficulty,
            setG11AcctPracticeDifficulty: controller.setPracticeDifficulty,
            g11AcctPracticeSubskill: controller.practiceSubskill,
            setG11AcctPracticeSubskill: controller.setPracticeSubskill,
            g11AcctPracticeSeed: controller.practiceSeed,
            setG11AcctPracticeSeed: controller.setPracticeSeed,
            fetchGrade11AccountingPractice: (params) => {
                // When fetching new practice, reset index
                setPracticeIndex(0);
                controller.fetchPractice(params);
            },
            g11AcctPracticeLoading: controller.practiceLoading,
            g11AcctPracticeError: controller.practiceError,
            g11AcctPracticeQuestions: controller.practiceQuestions,
            g11AcctPracticeAnswers: controller.practiceAnswers,
            setG11AcctPracticeAnswers: controller.setPracticeAnswers,
            g11AcctPracticeFeedback: controller.practiceFeedback,
            setG11AcctPracticeFeedback: controller.setPracticeFeedback,
            renderGrade11AccountingVisualAids,
            hideConfig: true,
            currentIndex: practiceIndex,
        }));
    }

    return null;
};

const Grade11ExponentsSurdsRoute = ({ workspaceMode, ctx }) => {
    const controller = useGrade11ExponentsSurdsController({ workspaceMode, buildApiUrl: ctx.buildApiUrl });

    const renderGrade11ExpSurdsVisualAids = () => h(Grade11ExponentsSurdsVisualAids);

    if (workspaceMode === 'grade11_exponents_surds_scaffold') {
        return h(Grade11ExponentsSurdsScaffold, {
            onBack: ctx.onBack,
            scaffoldSteps: controller.scaffoldSteps,
            g11ExpSurdsVisualAidsOpen: controller.visualAidsOpen,
            setG11ExpSurdsVisualAidsOpen: controller.setVisualAidsOpen,
            g11ExpSurdsScaffoldDifficulty: controller.scaffoldDifficulty,
            setG11ExpSurdsScaffoldDifficulty: controller.setScaffoldDifficulty,
            g11ExpSurdsScaffoldStepIndex: controller.scaffoldStepIndex,
            setG11ExpSurdsScaffoldStepIndex: controller.setScaffoldStepIndex,
            fetchGrade11ExpSurdsScaffoldQuestion: controller.fetchScaffoldQuestion,
            g11ExpSurdsScaffoldLoading: controller.scaffoldLoading,
            g11ExpSurdsScaffoldError: controller.scaffoldError,
            g11ExpSurdsScaffoldQuestion: controller.scaffoldQuestion,
            g11ExpSurdsScaffoldCheckpointIndex: controller.scaffoldCheckpointIndex,
            setG11ExpSurdsScaffoldCheckpointIndex: controller.setScaffoldCheckpointIndex,
            g11ExpSurdsScaffoldCheckpointAnswers: controller.scaffoldCheckpointAnswers,
            setG11ExpSurdsScaffoldCheckpointAnswers: controller.setScaffoldCheckpointAnswers,
            g11ExpSurdsScaffoldCheckpointFeedback: controller.scaffoldCheckpointFeedback,
            setG11ExpSurdsScaffoldCheckpointFeedback: controller.setScaffoldCheckpointFeedback,
            g11ExpSurdsScaffoldAnswer: controller.scaffoldAnswer,
            setG11ExpSurdsScaffoldAnswer: controller.setScaffoldAnswer,
            g11ExpSurdsScaffoldFeedback: controller.scaffoldFeedback,
            setG11ExpSurdsScaffoldFeedback: controller.setScaffoldFeedback,
            g11ExpSurdsScaffoldShowHint: controller.scaffoldShowHint,
            setG11ExpSurdsScaffoldShowHint: controller.setScaffoldShowHint,
            renderGrade11ExpSurdsVisualAids,
        });
    }

    if (workspaceMode === 'grade11_exponents_surds_practice') {
        return h(Grade11ExponentsSurdsPractice, {
            onBack: ctx.onBack,
            g11ExpSurdsPracticeQuestions: controller.practiceQuestions,
            g11ExpSurdsPracticeAnswers: controller.practiceAnswers,
            setG11ExpSurdsPracticeAnswers: controller.setPracticeAnswers,
            g11ExpSurdsPracticeFeedback: controller.practiceFeedback,
            g11ExpSurdsPracticeLoading: controller.practiceLoading,
            g11ExpSurdsPracticeError: controller.practiceError,
            g11ExpSurdsPracticeDifficulty: controller.practiceDifficulty,
            setG11ExpSurdsPracticeDifficulty: controller.setPracticeDifficulty,
            fetchGrade11ExpSurdsPractice: controller.fetchPractice,
            g11ExpSurdsVisualAidsOpen: controller.visualAidsOpen,
            setG11ExpSurdsVisualAidsOpen: controller.setVisualAidsOpen,
            renderGrade11ExpSurdsVisualAids,
        });
    }

    return null;
};

