            ctx,
            subskills: [
                { key: 'fixed-assets', title: 'Fixed / Tangible Assets' }
            ],
            defaultSubskill: 'fixed-assets'
        }),
    },
    grade11_accounting_fixed_assets_practice: {
        render: (ctx) => h(Grade11AccountingRoute, {
            workspaceMode: 'grade11_accounting_fixed_assets_practice',
            ctx,
            subskills: [
                { key: 'fixed-assets', title: 'Fixed / Tangible Assets' }
            ],
            defaultSubskill: 'fixed-assets'
